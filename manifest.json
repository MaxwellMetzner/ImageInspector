{
  "manifest_version": 3,
  "name": "Image Inspector",
  "short_name": "ImageInspector",
  "version": "0.1.0",
  "description": "Hover, inspect, download, and convert images from the current page.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Toggle Image Inspector",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "toggle-inspector": {
      "suggested_key": {
        "default": "Alt+Shift+I"
      },
      "description": "Toggle Image Inspector on the active tab"
    }
  }
}
